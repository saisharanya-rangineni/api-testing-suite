{
  "info": {
    "name": "ReqRes API Test Suite",
    "_postman_id": "portfolio-api-suite",
    "description": "Comprehensive API testing suite demonstrating CRUD operations, chained requests, schema validation, error handling, and edge cases against the public ReqRes API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const apiKey = pm.environment.get('apiKey');",
          "if (apiKey && apiKey !== 'YOUR_REQRES_API_KEY_HERE') {",
          "    pm.request.headers.add({ key: 'x-api-key', value: apiKey });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "User Management",
      "item": [
        {
          "name": "GET - List Users (Page 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Status code validation",
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Response time SLA",
                  "pm.test('Response time is under 2000ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "// Schema validation",
                  "const schema = JSON.parse(pm.environment.get('userListSchema'));",
                  "pm.test('Response matches JSON schema', () => {",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "});",
                  "",
                  "// Data integrity checks",
                  "const response = pm.response.json();",
                  "pm.test('Page number is 1', () => {",
                  "    pm.expect(response.page).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Data array is not empty', () => {",
                  "    pm.expect(response.data).to.be.an('array').that.is.not.empty;",
                  "});",
                  "",
                  "pm.test('Each user has required fields', () => {",
                  "    response.data.forEach(user => {",
                  "        pm.expect(user).to.have.all.keys('id', 'email', 'first_name', 'last_name', 'avatar');",
                  "        pm.expect(user.email).to.match(/^[^@]+@[^@]+\\.[^@]+$/);",
                  "        pm.expect(user.avatar).to.match(/^https?:\\/\\/.+/);",
                  "    });",
                  "});",
                  "",
                  "// Store first user ID for chained requests",
                  "pm.environment.set('userId', response.data[0].id);",
                  "pm.environment.set('totalPages', response.total_pages);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [{"key": "page", "value": "1"}]
            }
          }
        },
        {
          "name": "GET - Single User (Chained)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('User ID matches requested ID', () => {",
                  "    pm.expect(response.data.id).to.eql(parseInt(pm.environment.get('userId')));",
                  "});",
                  "",
                  "pm.test('User has valid email format', () => {",
                  "    pm.expect(response.data.email).to.match(/^[^@]+@[^@]+\\.[^@]+$/);",
                  "});",
                  "",
                  "pm.test('Support URL is present', () => {",
                  "    pm.expect(response.support).to.have.property('url');",
                  "    pm.expect(response.support.url).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "GET - User Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', () => {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Response body is empty object', () => {",
                  "    pm.expect(pm.response.json()).to.eql({});",
                  "});",
                  "",
                  "pm.test('Content-Type is JSON', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/99999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "99999"]
            }
          }
        },
        {
          "name": "POST - Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response contains user name', () => {",
                  "    pm.expect(response.name).to.eql('Sharanya');",
                  "});",
                  "",
                  "pm.test('Response contains job title', () => {",
                  "    pm.expect(response.job).to.eql('QA Automation Engineer');",
                  "});",
                  "",
                  "pm.test('Response contains generated ID', () => {",
                  "    pm.expect(response.id).to.not.be.undefined;",
                  "    pm.expect(parseInt(response.id)).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response contains createdAt timestamp', () => {",
                  "    pm.expect(response.createdAt).to.not.be.undefined;",
                  "    pm.expect(new Date(response.createdAt)).to.be.a('date');",
                  "});",
                  "",
                  "// Store for chained update/delete",
                  "pm.environment.set('createdUserId', response.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Sharanya\",\n    \"job\": \"QA Automation Engineer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "PUT - Update User (Chained)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Name is updated', () => {",
                  "    pm.expect(response.name).to.eql('Sharanya R');",
                  "});",
                  "",
                  "pm.test('Job is updated', () => {",
                  "    pm.expect(response.job).to.eql('Senior QA Automation Engineer');",
                  "});",
                  "",
                  "pm.test('updatedAt timestamp is present', () => {",
                  "    pm.expect(response.updatedAt).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Sharanya R\",\n    \"job\": \"Senior QA Automation Engineer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{createdUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{createdUserId}}"]
            }
          }
        },
        {
          "name": "DELETE - Remove User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', () => {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.test('Response body is empty', () => {",
                  "    pm.expect(pm.response.text()).to.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{createdUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{createdUserId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST - Register Successful",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response contains token', () => {",
                  "    pm.expect(response.token).to.not.be.undefined;",
                  "    pm.expect(response.token).to.be.a('string').that.is.not.empty;",
                  "});",
                  "",
                  "pm.test('Response contains user ID', () => {",
                  "    pm.expect(response.id).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.environment.set('authToken', response.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\",\n    \"password\": \"pistol\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "POST - Register Missing Password (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message indicates missing password', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.error).to.eql('Missing password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "POST - Login Successful",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token is returned', () => {",
                  "    pm.expect(pm.response.json().token).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\",\n    \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "POST - Login Missing Password (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message for missing password', () => {",
                  "    pm.expect(pm.response.json().error).to.eql('Missing password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"peter@klaven\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login"]
            }
          }
        }
      ]
    }
  ]
}
